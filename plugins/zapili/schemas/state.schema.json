{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oplya.dev/zapili/schemas/state.schema.json",
  "title": "zapili Orchestrator State",
  "description": "Contract for .zapili/state.json — single-writer cache derived from artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_path", "current_stage", "started_at", "updated_at"],
  "properties": {
    "schema_version": { "const": 1 },
    "task_path":      { "type": "string", "minLength": 1 },
    "current_stage":  { "enum": ["research", "research_validate", "plan", "plan_validate", "wave_execute", "wave_review", "wave_fix", "summarize", "complete"] },
    "current_wave":   { "type": ["integer", "null"], "minimum": 1 },
    "current_phase":  { "type": ["string", "null"], "pattern": "^[0-9]{2}-[0-9]{2}$" },
    "fix_loop_cap": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Per-validator fix-loop iteration cap; when reached with persistent HIGH findings, orchestrator dispatches codex-self-fix fallback (ZAP-60). Default 4 if absent."
    },
    "iteration_counters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["research_validate", "plan_validate", "per_phase_fix"],
      "properties": {
        "research_validate": { "type": "integer", "minimum": 0, "maximum": 10 },
        "plan_validate":     { "type": "integer", "minimum": 0, "maximum": 10 },
        "per_phase_fix": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0, "maximum": 10 }
        }
      }
    },
    "issue_ids": {
      "type": "object",
      "additionalProperties": false,
      "required": ["research_validate", "plan_validate", "per_phase_review"],
      "properties": {
        "research_validate": { "type": "array", "items": { "type": "string", "pattern": "^ISS-[0-9a-f]{12}$" } },
        "plan_validate":     { "type": "array", "items": { "type": "string", "pattern": "^ISS-[0-9a-f]{12}$" } },
        "per_phase_review": {
          "type": "object",
          "additionalProperties": { "type": "array", "items": { "type": "string", "pattern": "^ISS-[0-9a-f]{12}$" } }
        }
      }
    },
    "started_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
